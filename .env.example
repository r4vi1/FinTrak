# FinTrak — Environment Variables
# Copy this file to .env and fill in your values

# ── Server ──────────────────────────────────────────
PORT=3001

# ── Setu Account Aggregator (Optional) ──────────────
# Get these from https://bridge.setu.co after creating an FIU product
# Leave as-is to use the app with mock/seed data only
SETU_BASE_URL=https://fiu-uat.setu.co/v2
SETU_CLIENT_ID=
SETU_CLIENT_SECRET=
SETU_PRODUCT_INSTANCE_ID=
SETU_REDIRECT_URL=http://localhost:5173/accounts?consent=done
